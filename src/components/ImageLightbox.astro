---
import { Image } from 'astro:assets';

const { images = [] } = Astro.props;
---

<div class="grid gap-6 md:grid-cols-2">
  {images.map((item) => (
    <figure class="overflow-hidden rounded-xl border border-gray-700 bg-gray-900">
      <button
        type="button"
        class="block w-full cursor-zoom-in text-left"
        data-lightbox-trigger
        data-lightbox-src={item.src.src}
        data-lightbox-alt={item.alt}
      >
        <Image
          src={item.src}
          alt={item.alt}
          class="w-full object-cover transition duration-300 hover:scale-[1.02]"
        />
      </button>
      <figcaption class="p-4 text-sm text-gray-400">{item.caption}</figcaption>
    </figure>
  ))}
</div>

<div id="lightbox-overlay" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/85 p-4 backdrop-blur-sm">
  <button
    id="lightbox-close"
    class="absolute right-4 top-4 rounded-full border border-white/20 bg-white/10 px-3 py-2 text-xl text-white hover:bg-white/20"
    aria-label="Close image preview"
  >
    ×
  </button>
  <img id="lightbox-image" class="max-h-[90vh] max-w-[90vw] rounded-xl object-contain shadow-2xl" alt="" />
</div>

<script>
  const triggers = document.querySelectorAll('[data-lightbox-trigger]');
  const overlay = document.getElementById('lightbox-overlay');
  const image = document.getElementById('lightbox-image');
  const closeButton = document.getElementById('lightbox-close');

  const openLightbox = (src, alt) => {
    if (!overlay || !image) return;
    image.src = src;
    image.alt = alt;
    overlay.classList.remove('hidden');
    overlay.classList.add('flex');
    document.body.style.overflow = 'hidden';
  };

  const closeLightbox = () => {
    if (!overlay || !image) return;
    overlay.classList.add('hidden');
    overlay.classList.remove('flex');
    image.removeAttribute('src');
    image.alt = '';
    document.body.style.overflow = '';
  };

  triggers.forEach((trigger) => {
    trigger.addEventListener('click', () => {
      openLightbox(trigger.getAttribute('data-lightbox-src') || '', trigger.getAttribute('data-lightbox-alt') || '');
    });
  });

  closeButton?.addEventListener('click', closeLightbox);
  overlay?.addEventListener('click', (event) => {
    if (event.target === overlay) closeLightbox();
  });

  document.addEventListener('keydown', (event) => {
    if (event.key === 'Escape') closeLightbox();
  });
</script>
