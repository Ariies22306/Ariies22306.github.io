---
import Layout from '../layouts/Layout.astro';
---

<Layout title="My Portfolio">
    <main class="mx-auto max-w-4xl px-6 py-12 md:py-20">
        
        <header class="mb-20">
            <h1 class="mb-4 text-4xl font-extrabold tracking-tight sm:text-5xl text-white">
                Hi, I'm <span class="bg-gradient-to-r from-indigo-400 to-purple-400 bg-clip-text text-transparent">Faris</span>.
            </h1>
            <p class="text-lg text-gray-400">
                I'm a developer.
            </p>
        </header>

        <section class="mb-20">
            <h2 class="mb-8 text-2xl font-bold text-white">Featured Projects</h2>
            <div class="grid gap-6 sm:grid-cols-2">

                <div class="group rounded-xl border border-gray-800 bg-gray-900 p-6 transition-all hover:border-indigo-500/50 hover:bg-gray-800/80 hover:shadow-lg hover:shadow-indigo-500/10">
                    <h3 class="mb-2 text-xl font-semibold text-gray-100 group-hover:text-indigo-400 transition-colors">Abaki - AI Repository Monitor</h3>
                    <p class="mb-4 text-sm text-gray-400">.NET 8 REST API with AI-powered code auto-fixing, GitHub integration, and real-time updates.</p>
                    <a href="/abaki-overview" class="inline-flex items-center text-sm font-medium text-indigo-400 hover:text-indigo-300">
                        View Project 
                        <span class="ml-1 transition-transform group-hover:translate-x-1">&rarr;</span>
                    </a>
                </div>

                <div class="group rounded-xl border border-gray-800 bg-gray-900 p-6 transition-all hover:border-indigo-500/50 hover:bg-gray-800/80 hover:shadow-lg hover:shadow-indigo-500/10">
                    <h3 class="mb-2 text-xl font-semibold text-gray-100 group-hover:text-indigo-400 transition-colors">SYP Sozialkaufhaus</h3>
                    <p class="mb-4 text-sm text-gray-400">Spring Boot 3.4.5 backend for an online auction platform with real-time bidding and email integration.</p>
                    <a href="/syp-overview" class="inline-flex items-center text-sm font-medium text-indigo-400 hover:text-indigo-300">
                        View Project 
                        <span class="ml-1 transition-transform group-hover:translate-x-1">&rarr;</span>
                    </a>
                </div>

            </div>
        </section>

        <section class="mb-20">
            <h2 class="mb-8 text-2xl font-bold text-white">Skills & Tools</h2>
            <div class="flex flex-wrap gap-3">
                {['JavaScript', 'TypeScript', 'HTML', 'CSS', 'Postman', 'Git', 'C#', '.NET 8', 'Entity Framework Core', 'SQLite', 'SignalR', 'Java', 'Spring Boot', 'JPA/Hibernate', 'MS SQL Server', 'Log4j2', 'JUnit', 'Mockito', 'Artillery'].map((skill) => (
                    <span class="rounded-full border border-gray-700 bg-gray-800 px-4 py-2 text-sm font-medium text-gray-300 transition-colors hover:border-indigo-500/50 hover:text-white">
                        {skill}
                    </span>
                ))}
            </div>
        </section>
    </main>
</Layout>