---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Project One - My Portfolio">
    <main class="mx-auto max-w-4xl px-6 py-12 md:py-20">
        <a href="/" class="mb-8 inline-flex items-center text-sm font-medium text-indigo-400 hover:text-indigo-300">
            <span class="mr-2">&larr;</span>
            Back to Portfolio
        </a>

        <article>
            <header class="mb-12">
                <h1 class="mb-4 text-4xl font-extrabold tracking-tight sm:text-5xl text-white">
                    Project One
                </h1>
                <p class="text-lg text-gray-400">
                    A detailed look at one of my featured projects
                </p>
            </header>

            <section class="prose prose-invert max-w-none space-y-8">
                <div>
                    <h2 class="text-2xl font-bold text-white mb-4">Overview</h2>
                    <p class="text-gray-300 leading-relaxed">
                        Add a detailed description of your project here. Explain what problem it solves, 
                        the goals you were trying to achieve, and what makes it special.
                    </p>
                </div>

                <div>
                    <h2 class="text-2xl font-bold text-white mb-4">Project Image</h2>
                    <div class="rounded-lg overflow-hidden bg-gray-800 border border-gray-700 aspect-video flex items-center justify-center">
                        <p class="text-gray-500">Add your project image or screenshot here</p>
                    </div>
                </div>

                <div>
                    <h2 class="text-2xl font-bold text-white mb-4">Key Features</h2>
                    <ul class="space-y-3 text-gray-300">
                        <li class="flex items-start">
                            <span class="text-indigo-400 mr-3 font-bold">•</span>
                            <span>Feature one - describe what this feature does</span>
                        </li>
                        <li class="flex items-start">
                            <span class="text-indigo-400 mr-3 font-bold">•</span>
                            <span>Feature two - describe what this feature does</span>
                        </li>
                        <li class="flex items-start">
                            <span class="text-indigo-400 mr-3 font-bold">•</span>
                            <span>Feature three - describe what this feature does</span>
                        </li>
                    </ul>
                </div>

                <div>
                    <h2 class="text-2xl font-bold text-white mb-4">Technology Stack</h2>
                    <div class="flex flex-wrap gap-3">
                        {['Astro', 'Tailwind CSS', 'JavaScript', 'HTML'].map((tech) => (
                            <span class="rounded-full border border-indigo-500/30 bg-indigo-500/10 px-4 py-2 text-sm font-medium text-indigo-300">
                                {tech}
                            </span>
                        ))}
                    </div>
                </div>

                <div>
                    <h2 class="text-2xl font-bold text-white mb-4">Results & Impact</h2>
                    <p class="text-gray-300 leading-relaxed">
                        Share the outcome of this project. What did you learn? What impact did it have? 
                        Use metrics or concrete examples to showcase the results.
                    </p>
                </div>
            </section>
        </article>
    </main>
</Layout>